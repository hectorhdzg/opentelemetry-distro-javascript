{
  "name": "microsoft-opentelemetry",
  "version": "0.1.0",
  "description": "Microsoft OpenTelemetry distribution for JavaScript/TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "keywords": [
    "azure",
    "microsoft",
    "opentelemetry",
    "observability",
    "telemetry",
    "tracing",
    "metrics",
    "logging"
  ],
  "author": "Microsoft Corporation",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "rimraf": "^6.0.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@azure/monitor-opentelemetry": "^1.16.0"
  }
}
